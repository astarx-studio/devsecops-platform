{
  "realm": "devops",
  "enabled": true,
  "displayName": "DevOps Platform",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "editUsernameAllowed": false,
  "smtpServer": {
    "host": "${SMTP_HOST}",
    "port": "${SMTP_PORT}",
    "from": "${SMTP_FROM_EMAIL}",
    "fromDisplayName": "${SMTP_FROM_NAME}",
    "replyTo": "${SMTP_FROM_EMAIL}",
    "envelopeFrom": "${SMTP_FROM_EMAIL}",
    "ssl": "false",
    "starttls": "true",
    "auth": "true",
    "user": "${SMTP_USER}",
    "password": "${SMTP_PASSWORD}"
  },
  "bruteForceProtected": true,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator with full access",
        "composite": false
      },
      {
        "name": "developer",
        "description": "Developer with project access",
        "composite": false
      }
    ]
  },
  "defaultRoles": ["developer"],
  "groups": [
    {
      "name": "admins",
      "path": "/admins",
      "realmRoles": ["admin"]
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "description": "OpenID Connect scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "web-origins",
      "description": "OpenID Connect scope for allowed web origins",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "allowed web origins",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-allowed-origins-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },
    {
      "name": "groups",
      "description": "Maps user group memberships into JWT tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "group-membership",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "Maps realm roles into JWT access tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "roles",
    "groups"
  ],
  "clients": [
    {
      "clientId": "gitlab",
      "name": "GitLab CE",
      "description": "OIDC client for GitLab single sign-on",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "${KC_CLIENT_SECRET_GITLAB}",
      "redirectUris": [
        "https://${GITLAB_DOMAIN}/users/auth/openid_connect/callback"
      ],
      "webOrigins": [
        "https://${GITLAB_DOMAIN}"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://${GITLAB_DOMAIN}"
      },
      "defaultClientScopes": ["openid", "profile", "email", "roles", "groups"]
    },
    {
      "clientId": "vault",
      "name": "OpenBao",
      "description": "OIDC client for OpenBao UI authentication",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "${KC_CLIENT_SECRET_VAULT}",
      "redirectUris": [
        "https://${VAULT_DOMAIN}/ui/vault/auth/oidc/oidc/callback",
        "http://localhost:8250/oidc/callback"
      ],
      "webOrigins": [
        "https://${VAULT_DOMAIN}"
      ],
      "defaultClientScopes": ["openid", "profile", "email", "roles", "groups"]
    },
    {
      "clientId": "oauth2-proxy",
      "name": "OAuth2 Proxy",
      "description": "OIDC client for oauth2-proxy (protects Traefik dashboard and Kong admin)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "${KC_CLIENT_SECRET_OAUTH2_PROXY}",
      "redirectUris": ["https://${OAUTH_DOMAIN}/oauth2/callback"],
      "webOrigins": [
        "https://${TRAEFIK_DOMAIN}",
        "https://${KONG_DOMAIN}",
        "https://${OAUTH_DOMAIN}"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://${TRAEFIK_DOMAIN},https://${KONG_DOMAIN}"
      },
      "defaultClientScopes": ["openid", "profile", "email", "roles", "groups"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "${KEYCLOAK_ADMIN_EMAIL}",
      "firstName": "Platform",
      "lastName": "Admin",
      "realmRoles": ["admin", "developer"],
      "groups": ["/admins"],
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_ADMIN_PASSWORD}",
          "temporary": true
        }
      ]
    }
  ]
}
