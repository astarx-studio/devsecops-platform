# ============================================================================
# DevOps Platform — Environment Configuration
# ============================================================================
#
# Copy this file to .env and fill in the values:
#   cp sample.env .env
#
# ============================================================================

# ============================================================================
# DEPLOYMENT
# ============================================================================
NODE_ENV=production

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
# Platform services: *.devops.<DOMAIN>
# Deployed apps:     {projectName}.apps.<DOMAIN>
DOMAIN=yourdomain.com
APPS_DOMAIN=apps.yourdomain.com
DOCKER_NETWORK=devops-network

TRAEFIK_DOMAIN=traefik.devops.yourdomain.com
KEYCLOAK_DOMAIN=auth.devops.yourdomain.com
VAULT_DOMAIN=vault.devops.yourdomain.com
KONG_DOMAIN=gw.devops.yourdomain.com
KONG_ADMIN_DOMAIN=gw-admin.devops.yourdomain.com

GITLAB_DOMAIN=gitlab.devops.yourdomain.com
GITLAB_REGISTRY_DOMAIN=registry.devops.yourdomain.com
API_DOMAIN=api.devops.yourdomain.com
OAUTH_DOMAIN=oauth.devops.yourdomain.com

# ============================================================================
# TRAEFIK — Edge Router
# ============================================================================
TRAEFIK_ACME_EMAIL=your-email@example.com

# ============================================================================
# KONG — API Gateway
# ============================================================================
KONG_PG_HOST=kong-db
KONG_PG_PORT=5432
KONG_PG_DATABASE=kong
KONG_PG_USER=kong
KONG_PG_PASSWORD=change-me-kong-db-password
KONG_PROXY_LISTEN=0.0.0.0:8000, 0.0.0.0:8443 ssl
KONG_ADMIN_LISTEN=0.0.0.0:8001
KONG_LOG_LEVEL=info

# ============================================================================
# KEYCLOAK — OAuth2 / OIDC
# ============================================================================
# Admin credentials for the Keycloak admin console
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password
KEYCLOAK_ADMIN_EMAIL=admin@devops.yourdomain.com

# Keycloak database
KC_DB_HOST=keycloak-db
KC_DB_PORT=5432
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me-keycloak-db-password

# Keycloak hostname and proxy settings
KC_HOSTNAME=auth.devops.yourdomain.com
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true

# Keycloak realm name — used in OIDC URLs and shell scripts
KC_REALM=devops

# ============================================================================
# OPENBAO — Secrets Management (Vault-compatible, MPL 2.0)
# ============================================================================
# Dev mode: auto-unsealed with this token (no manual init/unseal needed)
# IMPORTANT: Token IDs should use alphanumeric + hyphens only.
# Prod mode: comment out VAULT_DEV_* vars and change the docker-compose
#            command from "server -dev" to "server -config=/vault/prod-config/config.hcl"
# Note: VAULT_* env var names are kept for backward compatibility with OpenBao.
VAULT_DEV_ROOT_TOKEN_ID=change-me-vault-dev-token
VAULT_ADDR=http://vault:8200

# ============================================================================
# CLOUDFLARE — Tunnel + DNS
# ============================================================================
# Used by:
#   - Traefik: ACME DNS-01 challenge for wildcard TLS certs (CF_DNS_API_TOKEN)
#   - cloudflared: outbound-only tunnel to Cloudflare edge (TUNNEL_TOKEN)
#   - Management API: DNS record + tunnel route management
#
# API Token permissions: Zone/DNS/Edit + Zone/Zone/Read
# How to create: Cloudflare Dashboard > My Profile > API Tokens > Create Token
CLOUDFLARE_API_TOKEN=change-me-cloudflare-api-token
# (Optional) Cloudflare zone for DNS automation
CLOUDFLARE_ZONE_ID=

# Tunnel token: Zero Trust > Networks > Tunnels > select tunnel > copy token
CLOUDFLARE_TUNNEL_TOKEN=change-me-cloudflare-tunnel-token
# (Optional) Cloudflare tunnel IDs for DNS automation
CLOUDFLARE_TUNNEL_ID=

# ============================================================================
# GITLAB CE — Source Control + CI/CD + Container Registry
# ============================================================================
# external_url must use HTTPS (TLS terminated at Traefik, not GitLab).
# Registry runs on a separate subdomain for Docker push/pull.
GITLAB_EXTERNAL_URL=https://gitlab.devops.yourdomain.com
GITLAB_REGISTRY_EXTERNAL_URL=https://registry.devops.yourdomain.com
GITLAB_ROOT_PASSWORD=change-me-gitlab-root-password

# ============================================================================
# GITLAB RUNNER — CI/CD Job Execution (Docker executor)
# ============================================================================
# >>> FILL_AFTER_STARTUP: GitLab Admin > CI/CD > Runners > New instance runner
#     Copy the runner authentication token (glrt-xxx), then:
#       docker compose up -d gitlab-runner
#     (do NOT use "restart" — env vars are only re-read on recreate)
GITLAB_RUNNER_TOKEN=FILL_AFTER_STARTUP

# ============================================================================
# MANAGEMENT API — NestJS Project Provisioning Orchestrator
# ============================================================================
# API key for protecting Management API endpoints.
# Leave empty to run without auth (dev mode).
API_KEY=change-me-management-api-key
API_PORT=3000
API_HOST=0.0.0.0

# GitLab PAT (api scope) for the Management API to fork templates,
# create groups, and manage projects. Create via:
#   GitLab > User Settings > Access Tokens > api scope
GITLAB_ROOT_TOKEN=change-me-gitlab-root-pat
# GitLab group ID containing template projects.
# After creating the "templates" group, note its numeric ID.
GITLAB_TEMPLATE_GROUP_ID=1
# GitLab group ID containing shared CI/CD config repos.
# After creating the "configs" group, note its numeric ID.
GITLAB_CONFIG_GROUP_ID=2

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# ============================================================================
# OIDC / KEYCLOAK — SSO Integration
# ============================================================================
# These secrets must match the values in keycloak/realm-export.json.
# After first boot, update the secrets in both places or use the Keycloak
# admin UI to regenerate them.
KC_CLIENT_SECRET_GITLAB=CHANGE-ME-GITLAB-CLIENT-SECRET
KC_CLIENT_SECRET_VAULT=CHANGE-ME-VAULT-CLIENT-SECRET
KC_CLIENT_SECRET_OAUTH2_PROXY=CHANGE-ME-OAUTH2-PROXY-CLIENT-SECRET

# OIDC URLs consumed by the Management API (external) and internal services.
# OIDC_ISSUER_URL  — the external Keycloak issuer URL (used by API + GitLab + openbao-oidc-init)
# OIDC_JWKS_URL    — internal JWKS endpoint for JWT validation (http://keycloak:8080/...)
# OAUTH2_PROXY_OIDC_ISSUER_URL — internal issuer URL for oauth2-proxy backchannel discovery
OIDC_ISSUER_URL=https://auth.devops.yourdomain.com/realms/devops
OIDC_JWKS_URL=http://keycloak:8080/realms/devops/protocol/openid-connect/certs
OIDC_AUDIENCE=management-api
OAUTH2_PROXY_OIDC_ISSUER_URL=http://keycloak:8080/realms/devops

# ============================================================================
# OAUTH2-PROXY — OIDC ForwardAuth for Traefik Dashboard + Kong Admin
# ============================================================================
# Cookie secret: exactly 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32 | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=change-me-32-byte-cookie-secret!

# ============================================================================
# SMTP — Outbound Email (GitLab + Keycloak)
# ============================================================================
# Shared SMTP configuration consumed by GitLab (notifications, invites) and
# Keycloak (password reset, email verification).
# Expects an external SMTP provider with STARTTLS on port 587.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM_NAME=DevOps Platform
SMTP_FROM_EMAIL=devops@yourdomain.com
SMTP_DOMAIN=yourdomain.com

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
