{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^jwks-rsa$": "<rootDir>/helpers/__mocks__/jwks-rsa.ts",
    "^@kubernetes/client-node$": "<rootDir>/helpers/kubernetes-client-node.e2e-mock.ts"
  }
}
