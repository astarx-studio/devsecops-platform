# Copy to forward-ports.env (do not commit secrets). Used by apply-nat.sh on the edge VM.
# Full fresh-VM steps: __DOCS__/99_maintainers/05_networking.md (Edge VM bootstrap + persistence).
#
# HOME_TRAFFIC_IP — IPv4 of the Docker *host* on your LAN where Traefik publishes
# 10080/10443 and GitLab SSH 12222 (same machine you run docker compose on).
# From WSL2: often the Windows host route; use `ip route show default` inside WSL
# or your router's DHCP lease for that PC.
HOME_TRAFFIC_IP=192.168.1.100

# Optional overrides (default: detect default route interface, wg0)
# WAN_IFACE=ens4
# WG_IFACE=wg0

# Comma-separated public_port:home_host_port (edge listens on public_port, forwards
# to HOME_TRAFFIC_IP:home_host_port over the WireGuard tunnel).
# Default matches this repo's docker-compose Traefik + GitLab SSH publish ports.
FORWARD_TCP=80:10080,443:10443,12222:12222
